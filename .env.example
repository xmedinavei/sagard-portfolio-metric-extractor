# Copy this file to .env.
# No API keys are required for the local fixture-based demo or for the local-parser path.
# For a zero-key local run, set `PDF_PARSER=local`.
# Provider keys are optional for preflight. Phase 2 uses Firecrawl when available and falls back
# to the local parser unless you explicitly disable fallback.

OPENAI_API_KEY=sk-your-openai-key-here
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here

PDF_PARSER=firecrawl
# valid values: firecrawl | local
FIRECRAWL_PDF_MODE=auto
# valid values: fast | auto | ocr
FIRECRAWL_TIMEOUT_SECONDS=60

OPENAI_MODEL=gpt-5.4-mini

# Optional Azure Document Intelligence settings
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-document-intelligence-key-here
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-layout
