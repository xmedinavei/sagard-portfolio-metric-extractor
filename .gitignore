# Environment and virtualenv
.env
.venv/

# Python cache / tooling
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Generated outputs
outputs/*
!outputs/.gitkeep
*.md.tmp

# OS/editor noise
.DS_Store
.vscode/

# Node / frontend
node_modules/

# Local scratch assets: the Sagard logo the app actually serves is committed under web/public/
# (and bundled into web/dist/). The repo-root static/ is just where the original download was
# saved — the app never reads it, so keep it out of version control.
/static/

# Demo-safety (Phase 4): the built cockpit bundle IS committed so `make serve` always has a
# known-good offline bundle to serve — never a live `npm run build` at demo time. web/dist is
# otherwise caught by the depth-agnostic `dist/` rule above, so we re-include the directory
# AND its contents: git cannot re-include a file whose parent directory stays excluded.
!web/dist/
!web/dist/**
# ...but a build's node_modules must never ride along, even though Vite never emits one
# into dist (defensive: re-exclude it AFTER the wildcard so the last match wins).
web/dist/node_modules/
